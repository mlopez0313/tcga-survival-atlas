# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Environment / local state
.env
.env.*
*.local

# Data + results (often large)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

results/models/*
results/figures/*
results/metrics/*
!results/models/.gitkeep
!results/figures/.gitkeep
!results/metrics/.gitkeep

logs/

# Multi-cohort outputs kept outside Git
mnt/datapool/
**/tcga_survival_cohorts/
**/tcga_survival_cohorts/**

# UUID-like generated/download directories occasionally created by
# dataset bundles or external tooling; keep source code elsewhere.
????????-????-????-????-????????????/

