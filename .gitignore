shiny_app/data_cache/
shiny_app/.Rproj.user/
shiny_app/rsconnect/

# Serialized model / analysis artefacts
*.pt
*.pth
*.pkl
*.joblib
*.rds
*.rda
*.RData
*.parquet

# Archives / exports
*.zip
*.tar
*.tar.gz
*.tgz

# OS / editor
.DS_Store
.idea/
.vscode/
